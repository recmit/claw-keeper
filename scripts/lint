#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if ! command -v uv >/dev/null 2>&1; then
  echo "scripts/lint: uv is required to run lint checks." >&2
  exit 1
fi

UV_CACHE_DIR="${UV_CACHE_DIR:-.uv-cache}" uv run ruff format --check src tests
UV_CACHE_DIR="${UV_CACHE_DIR:-.uv-cache}" uv run ruff check src tests
